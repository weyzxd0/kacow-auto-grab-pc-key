local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0.5, 0)
Title.BackgroundTransparency = 1
Title.Text = "SCRIPT BY KACOW"
Title.Font = Enum.Font.GothamBlack
Title.TextScaled = true
Title.TextColor3 = Color3.fromRGB(255,255,255)

local Status = Instance.new("TextLabel", Main)
Status.Size = UDim2.new(1, 0, 0.5, 0)
Status.Position = UDim2.new(0,0,0.5,0)
Status.BackgroundTransparency = 1
Status.Text = "INSTANT E : OFF  [Q]"
Status.Font = Enum.Font.GothamBold
Status.TextScaled = true
Status.TextColor3 = Color3.fromRGB(0,255,200)

local Active = false

local function Toggle()
	Active = not Active
	
	if Active then
		Status.Text = "INSTANT E : ACTIVE"
		Status.TextColor3 = Color3.fromRGB(0,255,150)
	else
		Status.Text = "INSTANT E : OFF  [Q]"
		Status.TextColor3 = Color3.fromRGB(0,255,200)
	end
end

UIS.InputBegan:Connect(function(i,gp)
	if not gp and i.KeyCode == Enum.KeyCode.Q then
		Toggle()
	end
end)

PPS.PromptButtonHoldBegan:Connect(function(prompt)
	if Active then
		prompt.HoldDuration = 0
		task.spawn(function()
			prompt:InputHoldBegin()
			prompt:InputHoldEnd()
			if fireproximityprompt then
				fireproximityprompt(prompt)
			end
		end)
	end
end)

end

